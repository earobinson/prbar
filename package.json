{
  "name": "prbar",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "PRBar - menu bar / system tray GitHub pull request monitor",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:release": "pnpm --filter @prbar/desktop generate:icons && pnpm --filter @prbar/desktop tauri build",
    "build:binaries": "pnpm --filter @prbar/desktop tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter @prbar/desktop dev",
    "tauri": "pnpm --filter @prbar/desktop tauri",
    "version:sync": "node packages/version/scripts/sync-version.mjs",
    "version:check": "node packages/version/scripts/sync-version.mjs --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.0"
  }
}
